    {
      "parameters": {
        "jsCode": "let inputData = {};\n\n// Kiểm tra xem Firebase có truyền dữ liệu qua không\nif ($input.first()) {\n  inputData = $input.first().json;\n}\n\nlet count = 0;\nlet lastTime = new Date(0);\nlet isSpam = false;\n\n// Nếu là khách cũ đã có dữ liệu\nif (inputData && inputData.messageCount !== undefined) {\n  count = Number(inputData.messageCount);\n  lastTime = new Date(inputData.lastMessageTime);\n}\n\nconst now = new Date();\nconst diffMinutes = (now - lastTime) / (1000 * 60);\n\nif (diffMinutes > 1) {\n  count = 1;\n} else {\n  count += 1;\n  if (count > 5) {\n    isSpam = true;\n  }\n}\n\nreturn {\n  // Thay đổi thành .first() để tránh lỗi treo liên kết item của n8n\n  documentId: $('Webhook').first().json.body.sessionId,\n  messageCount: count,\n  lastMessageTime: now.toISOString(),\n  isSpam: isSpam\n};"
      },
